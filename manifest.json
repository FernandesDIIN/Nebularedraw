{
  "id": "nebula.redraw.ai",
  "name": "NebulaRedraw AI",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "22.0.0"
    }
  ],
  "manifestVersion": 4,
  "entrypoints": [
    {
      "type": "panel",
      "id": "nebulaPanel",
      "label": {
        "default": "NebulaRedraw AI"
      },
      "minimumSize": {
        "width": 300,
        "height": 600
      },
      "maximumSize": {
        "width": 1200,
        "height": 1200
      },
      "preferredSize": {
        "width": 400,
        "height": 800
      }
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon-light.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium"
      ]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    },
    "clipboard": "readAndWrite"
  }
}
